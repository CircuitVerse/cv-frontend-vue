{
  "name": "cv-frontend-vue",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "serve": "vite preview",
    "build": "node scripts/multi-build.js",
    "dev": "node scripts/dev.js",
    "tauri": "tauri",
    "preview": "vite preview",
    "lint": "find . -name \"*.ts\" -not -path \"*/node_modules/*\" | xargs oxlint --ignore-path .gitignore",
    "lint:ci": "find . -name \"*.ts\" -not -path \"*/node_modules/*\" | xargs oxlint --ignore-path .gitignore --format=github",
    "lint:v1": "find v1 -name \"*.ts\" | xargs oxlint --deny-warnings",
    "lint:v1:ci": "find v1 -name \"*.ts\" | xargs oxlint --deny-warnings --format=github",
    "format": "oxfmt --write \"**/*.ts\"",
    "format:check": "oxfmt --check \"**/*.ts\"",
    "fmt:check": "npm run format:check",
    "postinstall": "husky install",
    "test": "vitest --silent",
    "test:src": "vitest run --project src",
    "test:v1": "vitest run --project v1",
    "test:src:ci": "vitest run --project src --reporter=github-actions",
    "test:v1:ci": "vitest run --project v1 --reporter=github-actions",
    "test:synthesis": "vitest run --project synthesis"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@mdi/font": "5.9.55",
    "@mdi/js": "^7.4.47",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tiptap/core": "^2.0.3",
    "@tiptap/extension-character-count": "^2.0.3",
    "@tiptap/extension-subscript": "^2.0.3",
    "@tiptap/extension-superscript": "^2.0.3",
    "@tiptap/extension-text-align": "^2.0.3",
    "@tiptap/extension-underline": "^2.0.3",
    "@tiptap/starter-kit": "^2.0.3",
    "@tiptap/vue-3": "^2.0.3",
    "@yowasp/yosys": "0.59.84-dev.1027",
    "bootstrap": "^4.6.1",
    "canvas-to-svg": "^1.0.3",
    "codemirror": "^5.65.1",
    "codemirror-editor-vue3": "^2.1.7",
    "dom-to-image": "^2.6.0",
    "driver.js": "^0.9.8",
    "interactjs": "^1.10.17",
    "jquery": "^3.6.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.7.9",
    "webfontloader": "^1.0.0",
    "yosys2digitaljs": "^0.10.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@intlify/unplugin-vue-i18n": "^6.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/jquery": "^3.5.14",
    "@types/webfontloader": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.3",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "sass": "^1.100.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.0"
  }
}
